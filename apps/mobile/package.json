{
  "name": "@bebe-taxi/mobile",
  "version": "1.0.0",
  "main": "App.tsx",
  "scripts": {
    "prestart": "node scripts/update-env-ip.js",
    "start": "expo start --clear",
    "dev": "node scripts/update-env-ip.js && expo start --clear",
    "android": "node scripts/update-env-ip.js && expo start --android --clear",
    "ios": "node scripts/update-env-ip.js && expo start --ios --clear",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-location": "~18.0.4",
    "expo-secure-store": "~14.0.0",
    "expo-image-picker": "~16.0.4",
    "expo-splash-screen": "~0.29.13",
    "expo-font": "~13.0.2",
    "react": "18.3.2",
    "react-native": "0.76.9",
    "react-native-maps": "1.18.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "react-native-screens": "~4.4.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-gesture-handler": "~2.20.2",
    "socket.io-client": "^4.7.5",
    "axios": "^1.7.9",
    "zustand": "^5.0.2",
    "@bebe-taxi/shared": "*"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "typescript": "^5.3.3"
  }
}
