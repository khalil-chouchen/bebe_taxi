# ── Mobile Environment Variables ──────────────────────────────────────────────
# All variables MUST be prefixed with EXPO_PUBLIC_ to be accessible in Expo.
# Do NOT add backend secrets here — this file is bundled into the mobile app.

# ── Backend URLs ───────────────────────────────────────────────────────────────
# These are auto-updated by apps/mobile/scripts/update-env-ip.js
# before Expo starts (via the "prestart" npm script).
# Your phone and laptop must be on the same Wi-Fi network.
EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:3001/api
EXPO_PUBLIC_SOCKET_URL=http://YOUR_LAN_IP:3001
EXPO_PUBLIC_MAPS_PROVIDER=default

# ── Google Maps (optional) ────────────────────────────────────────────────────
# Enables real road-based route polylines instead of straight-line fallback.
# Get a key at: https://console.cloud.google.com (enable Directions API)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
