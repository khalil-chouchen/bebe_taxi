# ── App ──────────────────────────────────────────────────────────────────────
PORT=3001
# Listen on all network interfaces so your phone can reach the backend via LAN.
# Use 127.0.0.1 to restrict to localhost only (e.g. in CI).
HOST=0.0.0.0
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/bebe_taxi

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=30d

# ── WhatsApp OTP ──────────────────────────────────────────────────────────────
# Set DEV_MODE=true to use mock OTP code (123456) — no real API calls
DEV_MODE=true

# Meta WhatsApp Cloud API (used when DEV_MODE=false)
META_WHATSAPP_TOKEN=your_meta_whatsapp_token
META_WHATSAPP_PHONE_ID=your_phone_number_id

# OR Twilio WhatsApp (alternative — set WHATSAPP_PROVIDER=twilio)
WHATSAPP_PROVIDER=meta
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Google Maps (optional — for route directions) ─────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MAPS_PROVIDER=google
ENABLE_MAPS_FALLBACK=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed (use * for development)
CORS_ORIGIN=*
